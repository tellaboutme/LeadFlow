APP_NAME=LeadFlow AI
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Optional. Unset defaults to backend/data/leadflow.db (created automatically).
# Override only to point at a different database.
# DATABASE_URL=sqlite:////absolute/path/to/leadflow.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# mock = no external calls (records only). Set to "openai" for real analysis.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
AI_TIMEOUT_SECONDS=30

# mock records messages without sending. Set to "telegram" to actually deliver
# via the Bot API (requires TELEGRAM_BOT_TOKEN). Keep real tokens in .env only.
TELEGRAM_PROVIDER=mock
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=10

# Generated API paths already include /api/v1, so this is the origin only.
# Leave empty in dev so requests use the Vite proxy (same-origin, no CORS).
# Set to an absolute origin (e.g. https://api.example.com) only when the
# backend is hosted separately. In Docker, nginx proxies /api, so leave it empty
# there too.
VITE_API_BASE_URL=

# --- Docker Compose only (ignored by the dev servers) -------------------------
# Host ports for `docker compose up`. Override if something already uses one;
# the app itself is reached at http://localhost:${FRONTEND_PORT}.
FRONTEND_PORT=8081
BACKEND_PORT=8000

# Inserts the synthetic demo leads on first boot. Idempotent across restarts.
SEED_ON_START=true
