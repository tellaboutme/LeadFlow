# Never ship secrets or local state into the build context.
.env
.env.*

# Local virtualenv: the image builds its own from uv.lock.
.venv/

# Local database files and any data directory contents.
data/
*.db
*.sqlite
*.sqlite3

# Caches and build artifacts.
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Not needed at runtime (tests run in CI, not in the production image).
tests/
