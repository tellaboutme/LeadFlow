# Never ship secrets into the build context.
.env
.env.*

# The image installs its own dependencies from package-lock.json.
node_modules/

# Build outputs and local artifacts (the image builds these itself).
dist/
storybook-static/
coverage/
lighthouseci/
.lighthouseci/
playwright-report/
test-results/

# Not needed to build the production bundle.
e2e/
