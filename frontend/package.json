{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --project jsdom --coverage",
    "preview": "vite preview",
    "schema:gen": "openapi-typescript ../openapi.json -o src/api/schema.d.ts",
    "schema:check": "openapi-typescript ../openapi.json -o src/api/schema.d.ts.check && diff src/api/schema.d.ts src/api/schema.d.ts.check && rm src/api/schema.d.ts.check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "openapi-fetch": "^0.17.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "msw-storybook-addon": "^2.0.7",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "storybook": "^10.5.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "msw@2.15.0": true,
    "esbuild@0.28.1": true
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
